generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
  SELLER
}

enum AuthUserStatus {
  ACTIVE
  DISABLED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  ASAAS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentTransactionType {
  CHARGE
  REFUND
  WEBHOOK
}

enum LinkType {
  PRODUCT
  STORE
  CATEGORY
  FLASH_SALE
  EXTERNAL
  NONE
}

enum PaymentTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  displayName String?
  phone       String?
  avatarUrl   String?
  role        UserRole @default(CUSTOMER)

  addresses       UserAddress[]
  storesFollowing StoreFollow[] @relation("UserFollowing")

  companiesOwned Company[]       @relation("CompanyOwner")
  orders         Order[]
  reviews        ProductReview[] @relation("UserReviews")
  authUsers      AuthUser[]
  auditLogs      AuditLog[]      @relation("AuditActorUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAddress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  description  String?
  zipCode      String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  isDefault    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Company {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  logoUrl     String?
  description String?

  ownerUserId String?
  owner       User?   @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  products  Product[]
  orders    Order[]
  followers StoreFollow[] @relation("StoreFollowers")
  auditLogs AuditLog[]    @relation("AuditCompany")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
}

/// Auth is intentionally decoupled from User.
model AuthUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  status       AuthUserStatus @default(ACTIVE)

  /// Optional link to a global User profile.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  sessions  AuthSession[]
  auditLogs AuditLog[]    @relation("AuditActorAuthUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AuthSession {
  id               String    @id @default(cuid())
  authUserId       String
  authUser         AuthUser  @relation(fields: [authUserId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  revokedAt        DateTime?

  createdAt DateTime @default(now())

  @@index([authUserId])
  @@index([revokedAt])
}

model Product {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status    ProductStatus @default(DRAFT)

  name        String
  description String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  variations ProductVariation[]
  images     ProductImage[]
  reviews    ProductReview[]    @relation("ProductReviews")
  flashSales FlashSale[]        @relation("FlashSaleProduct")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([categoryId])
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  imageUrl    String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  key       String
  url       String
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([productId, isPrimary])
}

model ProductVariation {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku           String?
  title         String?
  attributes    Json?
  priceCents    Int
  stockOnHand   Int     @default(0)
  stockReserved Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, sku])
  @@index([productId])
}

model Order {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  status    OrderStatus @default(PENDING_PAYMENT)

  customerUserId String?
  customer       User?   @relation(fields: [customerUserId], references: [id], onDelete: SetNull)

  currency        String @default("BRL")
  subtotalCents   Int    @default(0)
  shippingCents   Int    @default(0)
  discountCents   Int    @default(0)
  totalCents      Int    @default(0)
  shippingAddress Json?

  items    OrderItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([customerUserId])
  @@index([status])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String?
  variationId String?

  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int

  productSnapshot Json

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variationId])
}

model Payment {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider    PaymentProvider
  status      PaymentStatus   @default(PENDING)
  amountCents Int
  currency    String          @default("BRL")

  transactions PaymentTransaction[]
  refunds      Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([provider, status])
}

model PaymentTransaction {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  type   PaymentTransactionType
  status PaymentTransactionStatus @default(PENDING)

  providerTransactionId String?
  amountCents           Int?
  raw                   Json?

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([providerTransactionId])
  @@index([type, status])
}

model Refund {
  id          String       @id @default(cuid())
  paymentId   String
  payment     Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  status      RefundStatus @default(PENDING)
  amountCents Int
  raw         Json?

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([status])
}

model AuditLog {
  id String @id @default(cuid())

  actorAuthUserId String?
  actorAuthUser   AuthUser? @relation("AuditActorAuthUser", fields: [actorAuthUserId], references: [id], onDelete: SetNull)

  actorUserId String?
  actorUser   User?   @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  companyId String?
  company   Company? @relation("AuditCompany", fields: [companyId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ip         String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([actorAuthUserId])
  @@index([actorUserId])
  @@index([companyId])
  @@index([action])
  @@index([entityType, entityId])
}

model Coupon {
  id               String    @id @default(uuid())
  code             String    @unique
  discountType     String
  value            Int
  minPurchaseCents Int       @default(0)
  expirationDate   DateTime?
  isActive         Boolean   @default(true)
  maxUses          Int?
  usedCount        Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductReview {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  rating  Int     @db.SmallInt
  title   String?
  comment String?

  helpfulCount   Int @default(0)
  unhelpfulCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([rating])
}

model StoreFollow {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserFollowing", fields: [userId], references: [id], onDelete: Cascade)

  storeId String
  store   Company @relation("StoreFollowers", fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storeId])
  @@index([userId])
  @@index([storeId])
}

model FlashSale {
  id              String   @id @default(cuid())
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime
  discountPercent Int      @db.SmallInt
  isActive        Boolean  @default(true)

  productId String
  product   Product @relation("FlashSaleProduct", fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([startDate, endDate])
  @@index([isActive])
}

model CarouselBanner {
  id           String    @id @default(cuid())
  title        String?
  subtitle     String?
  imageUrl     String
  linkUrl      String?
  linkType     LinkType  @default(NONE)
  linkTargetId String?
  position     Int
  isActive     Boolean   @default(true)
  startDate    DateTime?
  endDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([position])
  @@index([isActive])
  @@index([startDate, endDate])
}

